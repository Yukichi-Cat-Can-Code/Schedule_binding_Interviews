# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/schedule_interview?retryWrites=true&w=majority
MONGODB_NAME=schedule_interview

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Algorithm Settings
GA_POPULATION_SIZE=100
GA_GENERATIONS=200
GA_CROSSOVER_RATE=0.8
GA_MUTATION_RATE=0.15

# Weights for Fitness Function
WEIGHT_CONFLICT=0.4
WEIGHT_IDLE=0.2
WEIGHT_FAIRNESS=0.2
WEIGHT_MATCHING=0.1
WEIGHT_ROOM=0.1
